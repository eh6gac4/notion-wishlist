# dev 中はダミーデータで動作させるなら 1 を指定（NOTION_TOKEN が無い場合は自動で 1 扱い）
# USE_MOCK_DATA=1

# Notion インテグレーションの Internal Integration Token
# https://www.notion.so/profile/integrations から作成
NOTION_TOKEN=secret_xxx

# Wishlist DB の ID
# DB ページ URL の "...notion.so/<workspace>/<DB_ID>?v=..." の <DB_ID> 部分（32 文字）
# 既知の値: 31a1690d811d45f7895dfe9ff0adf29b
NOTION_DATABASE_ID=31a1690d811d45f7895dfe9ff0adf29b

# 任意: Notion DB のプロパティ名が異なる場合に上書き
# NOTION_PROP_NAME=品名
# NOTION_PROP_URL=URL
# NOTION_PROP_PRICE=価格
# NOTION_PROP_STATUS=ステータス
# NOTION_PROP_PRIORITY=優先度
# NOTION_PROP_PURCHASE_DATE=購入予定日

# --- 認証 (NextAuth.js v5 / Credentials) ---
# JWT 署名キー。`openssl rand -base64 32` で生成
NEXTAUTH_SECRET=
# NEXTAUTH_URL は基本不要（auth.ts で trustHost: true のためリクエストの Host を採用）。
# 固定したい場合のみ設定。dev サーバーは port 3004 なので例: http://localhost:3004
# NEXTAUTH_URL=http://localhost:3004
# 単独所有者ログインのユーザー名・パスワード
APP_USERNAME=
APP_PASSWORD=

# --- Cloudflare デプロイ用（npm run cf:deploy / cf:preview / wrangler ... 実行時に必要） ---
# https://dash.cloudflare.com/profile/api-tokens で作成。
# 必要な権限: Account → Workers Scripts: Edit / Workers KV Storage: Edit / User Details: Read
CLOUDFLARE_API_TOKEN=cf_xxx
# https://dash.cloudflare.com/ 右上の Account ID
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
