# dev 中はダミーデータで動作させるなら 1 を指定（NOTION_TOKEN が無い場合は自動で 1 扱い）
# USE_MOCK_DATA=1

# Notion インテグレーションの Internal Integration Token
# https://www.notion.so/profile/integrations から作成
NOTION_TOKEN=secret_xxx

# Wishlist DB の ID
# DB ページ URL の "...notion.so/<workspace>/<DB_ID>?v=..." の <DB_ID> 部分（32 文字）
# 既知の値: 31a1690d811d45f7895dfe9ff0adf29b
NOTION_DATABASE_ID=31a1690d811d45f7895dfe9ff0adf29b

# 任意: Notion DB のプロパティ名が異なる場合に上書き
# NOTION_PROP_NAME=品名
# NOTION_PROP_URL=URL
# NOTION_PROP_PRICE=価格
# NOTION_PROP_STATUS=ステータス
# NOTION_PROP_PRIORITY=優先度
# NOTION_PROP_PURCHASE_DATE=購入予定日
